generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  CONTENT_MANAGER
  PROJECT_MANAGER
}

enum InquiryType {
  INVESTOR
  BRAND
  GENERAL
}

enum InquiryStatus {
  NEW
  READ
  REPLIED
  CLOSED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum PartnerType {
  DEVELOPER
  BRAND
  STRATEGIC
}

enum ProjectCategory {
  RESIDENTIAL
  COMMERCIAL
  MIXED_USE
  MASTER_PLANNED
  LUXURY
}

enum ProjectStatus {
  PLANNING
  UNDER_CONSTRUCTION
  COMPLETED
  LAUNCHED
  SOLD_OUT
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id           String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CONTENT_MANAGER)
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id              String          @id @default(cuid())
  titleEn         String
  titleAr         String
  slug            String          @unique
  descriptionEn   String          @db.Text
  descriptionAr   String          @db.Text
  locationEn      String
  locationAr      String
  category        ProjectCategory
  status          ProjectStatus
  images          Json            @default("[]")
  amenities       Json            @default("[]")
  availableSpaces Int?
  totalArea       String?
  completionDate  DateTime?
  featured        Boolean         @default(false)
  isDemo          Boolean         @default(true)
  investmentInfo  Json            @default("{}")
  published       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  media Media[]

  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([featured])
  @@index([published])
}

model Service {
  id          String   @id @default(cuid())
  titleEn     String
  titleAr     String
  slug        String   @unique
  descriptionEn String  @db.Text
  descriptionAr String  @db.Text
  icon        String?
  featuresEn  Json     @default("[]")
  featuresAr  Json     @default("[]")
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([order])
  @@index([published])
}

model Partner {
  id        String       @id @default(cuid())
  nameEn    String
  nameAr    String
  logo      String
  website   String?
  type      PartnerType  @default(DEVELOPER)
  published Boolean      @default(false)
  verified  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([type])
  @@index([published])
}

model BlogPost {
  id          String   @id @default(cuid())
  titleEn     String
  titleAr     String
  slug        String   @unique
  contentEn   String   @db.Text
  contentAr   String   @db.Text
  excerptEn   String?  @db.Text
  excerptAr   String?  @db.Text
  coverImage  String?
  author      String?
  tags        Json     @default("[]")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([createdAt])
}

model Inquiry {
  id           String        @id @default(cuid())
  type         InquiryType   @default(GENERAL)
  name         String
  company      String?
  email        String
  phone        String?
  message      String        @db.Text
  interestArea String?
  status       InquiryStatus @default(NEW)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model ContactRequest {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  company    String?
  message    String   @db.Text
  service    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
}

model Media {
  id        String    @id @default(cuid())
  url       String
  altEn     String?
  altAr     String?
  type      MediaType @default(IMAGE)
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([projectId])
  @@index([type])
}

model InvestmentMetric {
  id          String   @id @default(cuid())
  titleEn     String
  titleAr     String
  value       String
  descriptionEn String?
  descriptionAr String?
  source      String?
  icon        String?
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([order])
}

model SiteSetting {
  id          String @id @default(cuid())
  key         String @unique
  value       Json
  description String?
}

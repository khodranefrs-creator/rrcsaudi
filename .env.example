# =============================================================================
# RRC Saudi - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# On Vercel, set these in the project dashboard (Settings > Environment Variables).
# =============================================================================

# --- Database ---
# PostgreSQL connection string for Prisma ORM v7
# Required for: prisma generate, prisma migrate, runtime database access
DATABASE_URL="postgresql://postgres:password@localhost:5432/rrcsaudi?schema=public"

# --- NextAuth v5 ---
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-minimum-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# Optional Variables (add as needed)
# =============================================================================

# For production, set NEXTAUTH_URL to your Vercel deployment URL:
# NEXTAUTH_URL="https://rrcsaudi.vercel.app"

# If using Prisma Accelerate for connection pooling on Vercel:
# DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=your_key"
